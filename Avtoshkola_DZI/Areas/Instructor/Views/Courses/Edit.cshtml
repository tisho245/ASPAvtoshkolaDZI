@model StudentCourseInstance
@{
    ViewData["Title"] = "Редакция на курс";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Редакция на курс</h1>
        <p class="page-subtitle">Промяна на теоретични и практически часове</p>
    </div>
</section>

<section class="students-section">
    <div class="container-students">
        <div class="profile-card-wrapper">
            <div class="student-card profile-card">
                <div class="student-header">
                    <div class="student-avatar profile-avatar">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <div class="student-info">
                        <h3>@(Model.Student?.FirstName) @(Model.Student?.LastName)</h3>
                        <span class="badge bg-primary">
                            @(Model.CourseInstances?.Courses?.Name ?? "Курс")
                        </span>
                    </div>
                </div>
                <div class="student-body">
                    <p class="student-detail">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Заявка: @Model.CreateAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </p>
                    <p class="student-detail">
                        <i class="fas fa-car"></i>
                        <span>Автомобил: @(Model.Vehicles?.Brand) @(Model.Vehicles?.Model)</span>
                    </p>

                    <form asp-action="Edit" method="post" class="auth-form mt-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Теоретични часове</label>
                                <input class="form-control" type="number" name="currentTheoryHours" value="@Model.CurrentTheoryHours" min="0" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Практически часове</label>
                                <input class="form-control" type="number" name="currentPracticeHours" value="@Model.CurrentPracticeHours" min="0" />
                            </div>
                        </div>
                        <div class="profile-actions profile-actions-inline">
                            <button type="submit" class="btn-modern btn-primary-modern">
                                <i class="fas fa-save"></i> Запази
                            </button>
                            <a asp-area="Instructor" asp-controller="Home" asp-action="Index" class="btn-modern btn-secondary-modern">
                                <i class="fas fa-times"></i> Отказ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

