@model IEnumerable<StudentCourseInstance>
@{
    ViewData["Title"] = "Моите курсове";
}

<section class="page-header-modern">

    <div class="container">
        <h1 class="page-title">Моите курсове</h1>
        <p class="page-subtitle">Всички записи, в които сте инструктор</p>
    </div>

</section>
<section class="progress-section">
    <div class="container-progress">
        @if (!Model.Any())
        {
            <p class="text-muted">Нямате назначени записи.</p>
        }

        else
        {
            <div class="progress-grid">
                @foreach (var item in Model)
                {
                    var totalHours = item.CurrentTheoryHours + item.CurrentPracticeHours;
                    <div class="progress-card">
                        <div class="progress-icon bg-success">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <div class="progress-content">
                            <h3>@(item.Student?.FirstName) @(item.Student?.LastName)</h3>
                            <div class="progress-number">@totalHours ч.</div>
                            <p class="progress-label">
                                Курс: @(item.CourseInstances?.Courses?.Name ?? "Курс")
                            </p>
                            <p class="progress-label">
                                @(item.CourseInstances?.Description)
                            </p>
                            <p class="progress-label">
                                Автомобил: @(item.Vehicles?.Brand) @(item.Vehicles?.Model)
                            </p>
                            <p class="progress-label">
                                Заявка: @item.CreateAt.ToString("dd.MM.yyyy HH:mm")
                            </p>
                        </div>
                        <div class="student-footer profile-actions" style="margin-top: 1rem;">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-modern btn-secondary-modern btn-sm">
                                <i class="fas fa-eye"></i> Детайли
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-modern btn-primary-modern btn-sm">
                                <i class="fas fa-edit"></i> Редактирай
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-modern btn-danger-modern btn-sm">
                                <i class="fas fa-trash"></i> Изтрий
                            </a>
                        </div>
                    </div>
                }
            </div>

        }
    </div>

</section>