@model StudentCourseInstance
@{
    ViewData["Title"] = "Детайли за курс";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Детайли за курс</h1>
        <p class="page-subtitle">Информация за запис на курсист</p>
    </div>
</section>

<section class="students-section">
    <div class="container-students">
        <div class="profile-card-wrapper">
            <div class="student-card profile-card">
                <div class="student-header">
                    <div class="student-avatar profile-avatar">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <div class="student-info">
                        <h3>@(Model.Student?.FirstName) @(Model.Student?.LastName)</h3>
                        <span class="badge bg-primary">
                            @(Model.CourseInstances?.Courses?.Name ?? "Курс")
                        </span>
                    </div>
                </div>
                <div class="student-body">
                    <div class="student-detail">
                        <i class="fas fa-info-circle"></i>
                        <span>@(Model.CourseInstances?.Description)</span>
                    </div>
                    <div class="student-detail">
                        <i class="fas fa-car"></i>
                        <span>Автомобил: @(Model.Vehicles?.Brand) @(Model.Vehicles?.Model)</span>
                    </div>
                    <div class="student-detail">
                        <i class="fas fa-clock"></i>
                        <span>Теория: @Model.CurrentTheoryHours ч. · Практика: @Model.CurrentPracticeHours ч.</span>
                    </div>
                    <div class="student-detail">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Заявка: @Model.CreateAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                </div>
                <div class="student-footer profile-actions">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-modern btn-primary-modern btn-sm">
                        <i class="fas fa-edit"></i> Редактирай
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-modern btn-danger-modern btn-sm">
                        <i class="fas fa-trash"></i> Изтрий
                    </a>
                    <a asp-area="Instructor" asp-controller="Home" asp-action="Index" class="btn-modern btn-secondary-modern btn-sm">
                        <i class="fas fa-arrow-left"></i> Назад
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

