@model Avtoshkola_DZI.Data.StudentCourseInstance
@{
    ViewData["Title"] = "Изтриване на курс";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Изтриване на курс</h1>
        <p class="page-subtitle">Потвърдете изтриването на записа</p>
    </div>
</section>

<section class="students-section">
    <div class="container-students">
        <div class="profile-card-wrapper">
            <div class="student-card profile-card">
                <div class="student-header">
                    <div class="student-avatar profile-avatar">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <div class="student-info">
                        <h3>@(Model.Student?.FirstName) @(Model.Student?.LastName)</h3>
                        <span class="badge bg-danger">
                            @(Model.CourseInstances?.Courses?.Name ?? "Курс")
                        </span>
                    </div>
                </div>
                <div class="student-body">
                    <div class="student-detail">
                        <i class="fas fa-info-circle"></i>
                        <span>@(Model.CourseInstances?.Description)</span>
                    </div>
                    <div class="student-detail">
                        <i class="fas fa-clock"></i>
                        <span>Теория: @Model.CurrentTheoryHours ч. · Практика: @Model.CurrentPracticeHours ч.</span>
                    </div>
                    <div class="student-detail">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Заявка: @Model.CreateAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                </div>
                <div class="student-footer profile-actions">
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn-modern btn-danger-modern">
                            <i class="fas fa-trash"></i> Потвърди изтриване
                        </button>
                    </form>
                    <a asp-area="Instructor" asp-controller="Home" asp-action="Index" class="btn-modern btn-secondary-modern">
                        <i class="fas fa-times"></i> Отказ
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

