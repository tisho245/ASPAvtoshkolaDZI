@model IEnumerable<Avtoshkola_DZI.Data.StudentCourseInstance>
@{
    ViewData["Title"] = "Моите курсове";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Моите курсове</h1>
        <p class="page-subtitle">Записи, в които сте назначен като инструктор</p>
    </div>
</section>

<section class="progress-section">
    <div class="container-progress">
        <!-- Обобщение за инструктора -->
        <div class="dashboard-stats mb-4">
            <div class="stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-content">
                    <h3>Курсисти</h3>
                    <div class="stat-number">@ViewBag.TotalStudents</div>
                    <p class="stat-label">Общ брой активни курсисти</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="stat-content">
                    <h3>Записи</h3>
                    <div class="stat-number">@ViewBag.TotalEnrollments</div>
                    <p class="stat-label">Активни записвания за курсове</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-book"></i>
                </div>
                <div class="stat-content">
                    <h3>Теория</h3>
                    <div class="stat-number">@ViewBag.TotalTheoryHours</div>
                    <p class="stat-label">Общо проведени теоретични часове</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon bg-warning">
                    <i class="fas fa-car-side"></i>
                </div>
                <div class="stat-content">
                    <h3>Практика</h3>
                    <div class="stat-number">@ViewBag.TotalPracticeHours</div>
                    <p class="stat-label">Общо проведени практически часове</p>
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <p class="text-muted">Нямате назначени записи.</p>
        }
        else
        {
            <div class="progress-grid">
                @foreach (var item in Model)
                {
                    var totalHours = item.CurrentTheoryHours + item.CurrentPracticeHours;
                    <div class="progress-card">
                        <div class="progress-icon bg-success">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <div class="progress-content">
                            <h3>@(item.Student?.FirstName) @(item.Student?.LastName)</h3>
                            <div class="progress-number">@totalHours ч.</div>
                            <p class="progress-label">
                                Курс: @(item.CourseInstances?.Courses?.Name ?? "Курс")
                            </p>
                            <p class="progress-label">
                                @(item.CourseInstances?.Description)
                            </p>
                            <p class="progress-label">
                                Автомобил: @(item.Vehicles?.Brand) @(item.Vehicles?.Model)
                            </p>
                            <p class="progress-label">
                                Теория: @item.CurrentTheoryHours ч. · Практика: @item.CurrentPracticeHours ч.
                            </p>
                            <p class="progress-label">
                                Заявка: @item.CreateAt.ToString("dd.MM.yyyy HH:mm")
                            </p>
                        </div>
                        <div class="student-footer profile-actions" style="margin-top: 1rem;">
                            <a asp-area="Instructor" asp-controller="Courses" asp-action="Details" asp-route-id="@item.Id" class="btn-modern btn-secondary-modern btn-sm">
                                <i class="fas fa-eye"></i> Детайли
                            </a>
                            <a asp-area="Instructor" asp-controller="Courses" asp-action="Edit" asp-route-id="@item.Id" class="btn-modern btn-primary-modern btn-sm">
                                <i class="fas fa-edit"></i> Редактирай</a>
                            <a asp-area="Instructor" asp-controller="Courses" asp-action="Delete" asp-route-id="@item.Id" class="btn-modern btn-danger-modern btn-sm">
                                <i class="fas fa-trash"></i> Изтрий
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
