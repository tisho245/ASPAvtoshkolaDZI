@model Client
@{
    ViewData["Title"] = "Детайли курсист";
    string photoDataUrl = null;
    if (Model.PhotoData != null && Model.PhotoData.Length > 0)
    {
        var ct = "image/jpeg";
        if (Model.PhotoData.Length >= 4 && Model.PhotoData[0] == 0x89 && Model.PhotoData[1] == 0x50 && Model.PhotoData[2] == 0x4E && Model.PhotoData[3] == 0x47) ct = "image/png";
        else if (Model.PhotoData.Length >= 3 && Model.PhotoData[0] == 0x47 && Model.PhotoData[1] == 0x49 && Model.PhotoData[2] == 0x46) ct = "image/gif";
        else if (Model.PhotoData.Length >= 12 && Model.PhotoData[0] == 0x52 && Model.PhotoData[1] == 0x49 && Model.PhotoData[2] == 0x46 && Model.PhotoData[3] == 0x46 && Model.PhotoData[8] == 0x57 && Model.PhotoData[9] == 0x45 && Model.PhotoData[10] == 0x42 && Model.PhotoData[11] == 0x50) ct = "image/webp";
        photoDataUrl = "data:" + ct + ";base64," + Convert.ToBase64String(Model.PhotoData);
    }
    var enrollments = ViewBag.Enrollments as List<StudentCourseInstance> ?? new List<StudentCourseInstance>();
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Детайли курсист</h1>
        <p class="page-subtitle">@Model.FirstName @Model.LastName</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <!-- Информация за курсиста -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="row align-items-start">
                    @if (photoDataUrl != null)
                    {
                        <div class="col-md-3 text-center mb-3 mb-md-0">
                            <img src="@photoDataUrl" alt="Снимка" class="img-fluid rounded shadow-sm" style="max-height:180px; object-fit:cover" />
                        </div>
                    }
                    <div class="@(photoDataUrl != null ? "col-md-9" : "col-12")">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">Име</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(m => m.FirstName)</dd>
                            <dt class="col-sm-4 text-muted">Фамилия</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(m => m.LastName)</dd>
                            <dt class="col-sm-4 text-muted">Потребителско име</dt>
                            <dd class="col-sm-8">@Model.UserName</dd>
                            <dt class="col-sm-4 text-muted">E-mail</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(m => m.Email)</dd>
                            <dt class="col-sm-4 text-muted">Телефон</dt>
                            <dd class="col-sm-8">@(Model.PhoneNumber ?? "—")</dd>
                            <dt class="col-sm-4 text-muted">Дата на вписване</dt>
                            <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                            @if (!string.IsNullOrEmpty(Model.EGN))
                            {
                                <dt class="col-sm-4 text-muted">ЕГН</dt>
                                <dd class="col-sm-8">@Model.EGN</dd>
                            }
                            @if (!string.IsNullOrEmpty(Model.LicenseNumber))
                            {
                                <dt class="col-sm-4 text-muted">Номер на книжка</dt>
                                <dd class="col-sm-8">@Model.LicenseNumber</dd>
                            }
                            @if (!string.IsNullOrEmpty(Model.QualificationDesc))
                            {
                                <dt class="col-sm-4 text-muted">Квалификация</dt>
                                <dd class="col-sm-8">@Model.QualificationDesc</dd>
                            }
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <dt class="col-sm-4 text-muted">Бележки</dt>
                                <dd class="col-sm-8">@Model.Description</dd>
                            }
                        </dl>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <a asp-action="Index" class="btn-modern btn-secondary-modern btn-sm">
                        <i class="fas fa-arrow-left"></i> Назад към списъка
                    </a>
                </div>
            </div>
        </div>

        <!-- Прогрес на курсиста -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="fas fa-chart-line"></i> Прогрес по курсове</h5>
            </div>
            <div class="card-body">
                @if (!enrollments.Any())
                {
                    <div class="text-center py-4">
                        <i class="fas fa-graduation-cap fa-3x text-muted mb-3"></i>
                        <h6 class="text-muted">Няма активни курсове</h6>
                        <p class="text-muted">Този курсист все още няма записи за курсове.</p>
                    </div>
                }
                else
                {
                    <div class="row">
                        @foreach (var enrollment in enrollments)
                        {
                            <div class="col-md-6 col-lg-4 mb-3">
                                <div class="card h-100 border">
                                    <div class="card-body">
                                        <h6 class="card-title">@enrollment.CourseInstances?.Courses?.Name</h6>
                                        <p class="card-text small text-muted">
                                            <strong>Категория:</strong> @enrollment.CourseInstances?.Courses?.Categories?.Name<br>
                                            <strong>Начало:</strong> @enrollment.CourseInstances?.StartDate.ToString("dd.MM.yyyy")<br>
                                            <strong>Край:</strong> @enrollment.CourseInstances?.EndDate.ToString("dd.MM.yyyy")
                                        </p>
                                        <div class="progress mb-2" style="height: 8px;">
                                            @{
                                                var totalHours = enrollment.CourseInstances?.Courses?.TotalTheoryHours + enrollment.CourseInstances?.Courses?.TotalPracticeHours;
                                                var completedHours = enrollment.CurrentTheoryHours + enrollment.CurrentPracticeHours;
                                                var progressPercent = totalHours > 0 ? (completedHours * 100 / totalHours) : 0;
                                            }
                                            <div class="progress-bar" role="progressbar" style="width: @progressPercent%;" aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">@progressPercent%</div>
                                        </div>
                                        <div class="d-flex justify-content-between small">
                                            <span><i class="fas fa-book"></i> @enrollment.CurrentTheoryHours/@(enrollment.CourseInstances?.Courses?.TotalTheoryHours) теория</span>
                                            <span><i class="fas fa-car"></i> @enrollment.CurrentPracticeHours/@(enrollment.CourseInstances?.Courses?.TotalPracticeHours) практика</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(enrollment.Vehicles?.Brand))
                                        {
                                            <div class="mt-2 small text-muted">
                                                <i class="fas fa-car"></i> @enrollment.Vehicles.Brand @enrollment.Vehicles.Model
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>
