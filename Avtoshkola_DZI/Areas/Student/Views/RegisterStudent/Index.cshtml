@model Avtoshkola_DZI.Areas.Student.Controllers.RegisterStudentInputModel
@{
    ViewData["Title"] = "Регистрация като курсист";
}

<section class="auth-section">
    <div class="hero-background">
        <div class="hero-gradient"></div>
        <div class="hero-pattern"></div>
    </div>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Регистрация като курсист</h1>
                <p>Създайте акаунт за достъп до системата</p>
            </div>
            <form asp-area="Student" asp-controller="RegisterStudent" asp-action="Index" method="post" class="auth-form" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger" role="alert"></div>
                <div class="form-group">
                    <label asp-for="UserName" class="form-label">Потребителско име</label>
                    <input asp-for="UserName" class="form-control" autocomplete="username" required />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName" class="form-label">Име</label>
                        <input asp-for="FirstName" class="form-control" required />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="LastName" class="form-label">Фамилия</label>
                        <input asp-for="LastName" class="form-control" required />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Имейл</label>
                    <input asp-for="Email" class="form-control" type="email" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PhoneNumber" class="form-label">Телефон</label>
                    <input asp-for="PhoneNumber" class="form-control" type="tel" />
                </div>
                <div class="form-group">
                    <label for="Photo" class="form-label">Снимка</label>
                    <input type="file" id="Photo" name="Photo" class="form-control" accept="image/*" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Парола</label>
                        <input asp-for="Password" class="form-control" type="password" required />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Потвърди парола</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                <button type="submit" class="btn-auth">
                    <i class="fas fa-user-plus"></i>
                    <span>Регистрирай се</span>
                </button>
                <div class="auth-footer">
                    <p>Вече имате акаунт? <a asp-area="Identity" asp-page="/Account/Login">Влезте тук</a></p>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
