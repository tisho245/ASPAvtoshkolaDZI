@model             Client
@using Avtoshkola_DZI.Models
@{
    ViewData["Title"] = "Инструктор";
    var activeCourses = ViewBag.ActiveCourses as IEnumerable<StudentCourseInstance> ?? Enumerable.Empty<StudentCourseInstance>();
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Инструктор: @Model.FirstName @Model.LastName</h1>
        <p class="page-subtitle">Детайлна информация за инструктора</p>
    </div>
</section>

<section class="details-section">
    <div class="container">
        <div class="details-layout">
            <div class="details-main">
                <h2>Профил</h2>
                <dl class="details-list">
                    <dt>Име</dt>
                    <dd>@Model.FirstName @Model.LastName</dd>

                    <dt>Имейл</dt>
                    <dd>@Model.Email</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <dt>Телефон</dt>
                        <dd>@Model.PhoneNumber</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.QualificationDesc))
                    {
                        <dt>Квалификация</dt>
                        <dd>@Model.QualificationDesc</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.LicenseNumber))
                    {
                        <dt>Номер на лиценз</dt>
                        <dd>@Model.LicenseNumber</dd>
                    }
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <h3>Описание</h3>
                    <p>@Model.Description</p>
                }
            </div>

            <aside class="details-aside">
                <h3>Активни курсове</h3>
                @if (!activeCourses.Any())
                {
                    <p class="text-muted">В момента няма активни записи за курсове с този инструктор.</p>
                }
                else
                {
                    <ul class="list-simple">
                        @foreach (var e in activeCourses)
                        {
                            <li>
                                <strong>@(e.CourseInstances?.Courses?.Name ?? "Курс")</strong><br />
                                <small>Курсист: @(e.Student?.FirstName) @(e.Student?.LastName)</small><br />
                                <small>Часове: @(e.CurrentTheoryHours + e.CurrentPracticeHours)</small>
                            </li>
                        }
                    </ul>
                }
            </aside>
        </div>

        <div class="details-actions">
            <a asp-action="Index" class="btn-modern btn-secondary-modern">Назад към списъка</a>
        </div>
    </div>
</section>

