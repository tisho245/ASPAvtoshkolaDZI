@page
@model Avtoshkola_DZI.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Смяна на парола";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Смяна на парола</h1>
        <p class="page-subtitle">Въведете текущата и новата парола</p>
    </div>
</section>

<section class="students-section">
    <div class="container-students">
        <div class="profile-card-wrapper">
            <div class="auth-card profile-edit-card">
                <form method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="form-group">
                        <label asp-for="Input.OldPassword" class="form-label">Текуща парола</label>
                        <input asp-for="Input.OldPassword" class="form-control" type="password" autocomplete="current-password" />
                        <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.NewPassword" class="form-label">Нова парола</label>
                        <input asp-for="Input.NewPassword" class="form-control" type="password" autocomplete="new-password" />
                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Потвърди нова парола</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="profile-actions profile-actions-inline">
                        <button type="submit" class="btn-modern btn-primary-modern">
                            <i class="fas fa-key"></i> Смени парола
                        </button>
                        <a asp-page="./Index" class="btn-modern btn-secondary-modern">
                            <i class="fas fa-times"></i> Отказ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
