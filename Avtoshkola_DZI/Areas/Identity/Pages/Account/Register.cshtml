@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<section class="auth-section">
    <div class="hero-background">
        <div class="hero-gradient"></div>
        <div class="hero-pattern"></div>
    </div>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Регистрация</h1>
                <p>Създайте нов акаунт</p>
            </div>
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-group">
                    <label asp-for="Input.UserName" class="form-label">Потребителско име</label>
                    <input asp-for="Input.UserName" class="form-control" autocomplete="username" required />
                    <span asp-validation-for="Input.UserName" class="text-danger"></span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.FirstName" class="form-label">Име</label>
                        <input asp-for="Input.FirstName" class="form-control" required />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.LastName" class="form-label">Фамилия</label>
                        <input asp-for="Input.LastName" class="form-control" required />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Input.Email" class="form-label">Имейл</label>
                    <input asp-for="Input.Email" class="form-control" type="email" autocomplete="email" required />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.PhoneNumber" class="form-label">Телефон</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" type="tel" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Password" class="form-label">Парола</label>
                        <input asp-for="Input.Password" class="form-control" type="password" autocomplete="new-password" required />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Потвърди парола</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" required />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                <button type="submit" class="btn-auth">
                    <i class="fas fa-user-plus"></i>
                    <span>Регистрирай се</span>
                </button>
                <div class="auth-footer">
                    <p>Вече имате акаунт? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Влезте тук</a></p>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
