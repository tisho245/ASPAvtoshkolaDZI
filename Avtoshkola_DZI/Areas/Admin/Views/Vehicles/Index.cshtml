@model IEnumerable<Avtoshkola_DZI.Data.Vehicle>
@{
    ViewData["Title"] = "Автомобили";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Автомобили</h1>
        <p class="page-subtitle">Учебни автомобили по категории</p>
    </div>
</section>

<section class="services-section">
    <div class="container-services">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h5 mb-0">Учебни автомобили</h2>
            <a asp-action="Create" class="btn-modern btn-primary-modern">
                <span>Добави автомобил</span>
                <i class="fas fa-plus"></i>
            </a>
        </div>

        <div class="students-grid">
            @foreach (var item in Model)
            {
                <div class="student-card">
                    <div class="student-header">
                        <div class="student-avatar">
                            <i class="fas fa-car-side"></i>
                        </div>
                        <div class="student-info">
                            <h3>@item.Brand @item.Model</h3>
                            <span class="badge bg-primary">@item.Categories?.Name</span>
                        </div>
                    </div>
                    <div class="student-body">
                        <div class="student-detail">
                            <i class="fas fa-hashtag"></i>
                            <span>ID: @item.Id</span>
                        </div>
                        <div class="student-detail">
                            <i class="fas fa-calendar-alt"></i>
                            <span>Година: @item.Year</span>
                        </div>
                        <div class="student-detail">
                            <i class="fas fa-cog"></i>
                            <span>Скоростна кутия: @(item.IsAutomatic ? "Автоматик" : "Ръчна")</span>
                        </div>
                        <div class="student-detail">
                            <i class="fas fa-clock"></i>
                            <span>В системата от @item.CreatedAt.ToString("dd.MM.yyyy")</span>
                        </div>
                    </div>
                    <div class="student-footer">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-modern btn-secondary-modern btn-sm">
                            <i class="fas fa-eye"></i> Детайли
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-modern btn-primary-modern btn-sm">
                            <i class="fas fa-edit"></i> Редактирай
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-modern btn-danger-modern btn-sm">
                            <i class="fas fa-trash"></i> Изтрий
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
