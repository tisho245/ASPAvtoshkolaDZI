@model IEnumerable<CourseInstance>
@{
    ViewData["Title"] = "Текущи курсове";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Текущи курсове</h1>
        <p class="page-subtitle">Активни инстанции на обучения</p>
    </div>
</section>

<section class="students-section">
    <div class="container-students">
        <div class="section-actions">
            <a asp-action="Create" class="btn-modern btn-primary-modern">
                <i class="fas fa-plus"></i>
                <span>Добави текущ курс</span>
            </a>
        </div>

        <div class="students-grid">
            @foreach (var item in Model)
            {
                var durationDays = (item.EndDate.ToDateTime(TimeOnly.MinValue) - item.StartDate.ToDateTime(TimeOnly.MinValue)).Days;

                <div class="student-card">
                    <div class="student-header">
                        <div class="student-avatar">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <div class="student-info">
                            <h3>@(item.Courses?.Name ?? "Курс")</h3>
                            <span class="badge bg-primary">Курс № @item.Id</span>
                        </div>
                    </div>
                    <div class="student-body">
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <div class="student-detail">
                                <i class="fas fa-info-circle"></i>
                                <span>
                                    @(item.Description.Length > 80
                                        ? item.Description.Substring(0, 80) + "…"
                                        : item.Description)
                                </span>
                            </div>
                        }
                        <div class="student-detail">
                            <i class="fas fa-play-circle"></i>
                            <span>Начало: @item.StartDate.ToString("dd.MM.yyyy")</span>
                        </div>
                        <div class="student-detail">
                            <i class="fas fa-flag-checkered"></i>
                            <span>Край: @item.EndDate.ToString("dd.MM.yyyy")</span>
                        </div>
                        <div class="student-detail">
                            <i class="fas fa-clock"></i>
                            <span>Продължителност: @durationDays дни</span>
                        </div>
                    </div>
                    <div class="student-footer">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-modern btn-secondary-modern btn-sm">
                            <i class="fas fa-eye"></i> Детайли
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-modern btn-primary-modern btn-sm">
                            <i class="fas fa-edit"></i> Редактирай
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-modern btn-danger-modern btn-sm">
                            <i class="fas fa-trash"></i> Изтрий
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
