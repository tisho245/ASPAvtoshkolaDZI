@model Avtoshkola_DZI.Data.CourseInstance
@{
    ViewData["Title"] = "Изтрий текущ курс";
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Изтрий текущ курс</h1>
        <p class="page-subtitle">Потвърдете изтриването</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="alert alert-danger mb-4" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Сигурни ли сте, че искате да изтриете този текущ курс? Действието не може да бъде отменено.
                </div>
                <dl class="row mb-4">
                    <dt class="col-sm-3 text-muted">Номер на курс</dt>
                    <dd class="col-sm-9">@Model.Id</dd>
                    <dt class="col-sm-3 text-muted">Обучение</dt>
                    <dd class="col-sm-9">@(Model.Courses?.Name)</dd>
                    <dt class="col-sm-3 text-muted">Описание</dt>
                    <dd class="col-sm-9">@(Model.Description?.Length > 80 ? Model.Description.Substring(0, 80) + "…" : (Model.Description ?? "—"))</dd>
                </dl>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn-modern btn-danger-modern">
                            <i class="fas fa-trash"></i> Изтрий
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-modern btn-secondary-modern">Отказ</a>
                        <a asp-action="Index" class="btn-modern btn-secondary-modern">
                            <i class="fas fa-arrow-left"></i> Назад към списъка
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
