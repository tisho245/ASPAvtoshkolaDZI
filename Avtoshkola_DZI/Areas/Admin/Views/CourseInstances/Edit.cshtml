@model CourseInstance
@{
    ViewData["Title"] = "Редактирай текущ курс";
    var durationDays = (Model.EndDate.ToDateTime(TimeOnly.MinValue) - Model.StartDate.ToDateTime(TimeOnly.MinValue)).Days;
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Редактирай текущ курс</h1>
        <p class="page-subtitle">Курс № @Model.Id – @(Model.Courses?.Name)</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="CourseId" class="form-label">Обучение</label>
                            <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId"></select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Описание и изисквания</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label">Начална дата</label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label">Крайна дата</label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                        </div>
                        <div class="col-12 text-muted small">Продължителност: @durationDays дни</div>
                    </div>
                    <hr class="my-4" />
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn-modern btn-primary-modern">
                            <i class="fas fa-save"></i> Запази
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-modern btn-secondary-modern">Отказ</a>
                        <a asp-action="Index" class="btn-modern btn-secondary-modern">
                            <i class="fas fa-arrow-left"></i> Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
