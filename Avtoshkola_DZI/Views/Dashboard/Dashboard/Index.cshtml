@using Avtoshkola_DZI.Models
@{
    ViewData["Title"] = "Табло";
    var recentEnrollments = ViewBag.RecentEnrollments as IEnumerable<StudentCourseInstance> ?? Enumerable.Empty<StudentCourseInstance>();
}

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Табло</h1>
        <p class="page-subtitle">Добре дошли в системата за управление</p>
    </div>
</section>

<section class="dashboard-section">
    <div class="container-dashboard">
        <div class="dashboard-stats">
            <div class="stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-content">
                    <h3>Курсисти</h3>
                    <div class="stat-number">@(ViewBag.StudentsCount ?? 0)</div>
                    <p class="stat-label">общо в системата</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-chalkboard-teacher"></i>
                </div>
                <div class="stat-content">
                    <h3>Инструктори</h3>
                    <div class="stat-number">@(ViewBag.InstructorsCount ?? 0)</div>
                    <p class="stat-label">активни инструктори</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="stat-content">
                    <h3>Записи</h3>
                    <div class="stat-number">@(ViewBag.EnrollmentsCount ?? 0)</div>
                    <p class="stat-label">курсни записвания</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon bg-warning">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-content">
                    <h3>Курсове</h3>
                    <div class="stat-number">@(ViewBag.TotalHours ?? 0)</div>
                    <p class="stat-label">теория + практика</p>
                </div>
            </div>
        </div>

        <div class="dashboard-actions">
            <h2><i class="fas fa-bolt"></i> Бързи действия</h2>
            <div class="actions-grid">
                <a asp-area="Admin" asp-controller="Enrollments" asp-action="Index" class="action-card">
                    <div class="action-icon">
                        <i class="fas fa-calendar-plus"></i>
                    </div>
                    <span>Записи за курсове</span>
                </a>
                <a asp-area="Admin" asp-controller="Students" asp-action="Index" class="action-card">
                    <div class="action-icon action-icon-green">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <span>Курсисти</span>
                </a>
                <a asp-area="" asp-controller="Messages" asp-action="Index" class="action-card">
                    <div class="action-icon action-icon-orange">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <span>Съобщения</span>
                </a>
            </div>
        </div>

        @if (recentEnrollments.Any())
        {
            <div class="dashboard-recent">
                <h2><i class="fas fa-history"></i> Последни записи</h2>
                <div class="recent-list">
                    @foreach (var e in recentEnrollments)
                    {
                        <div class="recent-item">
                            <div class="recent-icon">
                                <i class="fas fa-car"></i>
                            </div>
                            <div class="recent-info">
                                <h4>@(e.CourseInstances?.Courses?.Name ?? "Курс") – @(e.Student?.FirstName) @(e.Student?.LastName)</h4>
                                <p>Инструктор: @(e.Instructor?.FirstName) @(e.Instructor?.LastName)</p>
                            </div>
                            <div class="recent-time">
                                <span class="badge bg-primary">@(e.CurrentTheoryHours + e.CurrentPracticeHours) ч.</span>
                                <small>@e.CreateAt.ToString("dd.MM.yyyy")</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
