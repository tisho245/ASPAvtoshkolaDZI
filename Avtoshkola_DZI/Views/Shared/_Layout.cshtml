@using Avtoshkola_DZI.Models
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Автошкола</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body style="overflow-x: hidden; width: 100%;">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-car-side"></i> Автошкола
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Превключване на навигация">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navbarContent" style="overflow: visible;">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> <span>Начало</span></a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="About"><i class="fas fa-info-circle"></i> <span>За нас</span></a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Services"><i class="fas fa-concierge-bell"></i> <span>Услуги</span></a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contact"><i class="fas fa-address-card"></i> <span>Контакти</span></a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy"><i class="fas fa-shield-alt"></i> <span>Поверителност</span></a></li>
                    </ul>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav">
                            @if (User.IsInRole(RoleNames.Administrator))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="fas fa-cogs"></i> Админ панел</a>
                                    <ul class="dropdown-menu">
                                        <li><h6 class="dropdown-header">Управление на данни</h6></li>
                                        <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index"><i class="fas fa-tags"></i> Категории</a></li>
                                        <li><a class="dropdown-item" asp-controller="Courses" asp-action="Index"><i class="fas fa-graduation-cap"></i> Обучения</a></li>
                                        <li><a class="dropdown-item" asp-controller="CourseInstances" asp-action="Index"><i class="fas fa-calendar-check"></i> Текущи курсове</a></li>
                                        <li><a class="dropdown-item" asp-controller="Vehicles" asp-action="Index"><i class="fas fa-car"></i> Автомобили</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><h6 class="dropdown-header">Управление на потребители</h6></li>
                                        <li><a class="dropdown-item" asp-controller="Instructors" asp-action="Index"><i class="fas fa-chalkboard-teacher"></i> Инструктори</a></li>
                                        <li><a class="dropdown-item" asp-controller="Students" asp-action="Index"><i class="fas fa-user-graduate"></i> Курсисти</a></li>
                                        <li><a class="dropdown-item" asp-controller="Enrollments" asp-action="Index"><i class="fas fa-user-plus"></i> Записи за курсове</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Табло</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole(RoleNames.Instructor))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="fas fa-cogs"></i> Инструменти</a>
                                    <ul class="dropdown-menu">
                                        <li><h6 class="dropdown-header">Управление на курсове</h6></li>
                                        <li><a class="dropdown-item" asp-controller="Enrollments" asp-action="Index"><i class="fas fa-list"></i> Детайли на курсове</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><h6 class="dropdown-header">Преглед на курсисти</h6></li>
                                        <li><a class="dropdown-item" asp-controller="Students" asp-action="MyStudents"><i class="fas fa-users"></i> Мои курсисти</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole(RoleNames.Student))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Student" asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> <span>Табло</span></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Student" asp-controller="Home" asp-action="MyEnrollments"><i class="fas fa-users"></i> <span>Моите записи</span></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Enrollments" asp-action="Request"><i class="fas fa-file-alt"></i> <span>Заяви курс</span></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="Student" asp-controller="Progress" asp-action="Index"><i class="fas fa-chart-line"></i> <span>Моят прогрес</span></a>
                                </li>
                            }
                        </ul>
                        <partial name="_LoginPartial" />
                    }
                    else {
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-area="Student" asp-controller="RegisterStudent" asp-action="Index"><i class="fas fa-user-plus"></i> Регистрация</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login"><i class="fas fa-sign-in-alt"></i> Вход</a></li>
                    </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>
    <footer class="border-top footer text-muted">
        <div class="container">
            <div class="row" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
                <div class="col-md-6 text-md-start text-center" style="flex: 1; min-width: 200px;">
                    &copy; @DateTime.Now.Year - Автошкола - Управление на автошкола
                </div>
                <div class="col-md-6 text-md-end text-center" style="flex: 1; min-width: 200px;">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Политика за поверителност</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/main.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
