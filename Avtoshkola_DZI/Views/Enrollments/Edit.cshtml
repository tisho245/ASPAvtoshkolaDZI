@model StudentCourseInstance
@{
    ViewData["Title"] = "Редактирай записване";
    var maxTheoryHours = Model.CourseInstances?.Courses?.TotalTheoryHours ?? 0;
    var maxPracticeHours = Model.CourseInstances?.Courses?.TotalPracticeHours ?? 0;
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var maxTheory = @maxTheoryHours;
        var maxPractice = @maxPracticeHours;
        
        var theoryInput = document.querySelector('input[name="currentTheoryHours"]');
        var practiceInput = document.querySelector('input[name="currentPracticeHours"]');
        var form = document.querySelector('form');
        
        if (!theoryInput || !practiceInput || !form) return;
        
        // Добавяне на информация за лимитите
        theoryInput.setAttribute('max', maxTheory);
        practiceInput.setAttribute('max', maxPractice);
        
        // Добавяне на текст за максималните часове
        var theoryLabel = theoryInput.previousElementSibling;
        var practiceLabel = practiceInput.previousElementSibling;
        
        if (theoryLabel) {
            var theoryInfo = document.createElement('small');
            theoryInfo.className = 'text-muted d-block';
            theoryInfo.textContent = ' Максимум: ' + maxTheory + ' часа';
            theoryLabel.parentNode.insertBefore(theoryInfo, theoryInput.nextSibling);
        }
        
        if (practiceLabel) {
            var practiceInfo = document.createElement('small');
            practiceInfo.className = 'text-muted d-block';
            practiceInfo.textContent = ' Максимум: ' + maxPractice + ' часа';
            practiceLabel.parentNode.insertBefore(practiceInfo, practiceInput.nextSibling);
        }
        
        // Функция за валидация
        function validateHours(input, maxValue, fieldName) {
            var value = parseInt(input.value) || 0;
            var isValid = true;
            
            // Премахване на стари грешки
            input.classList.remove('is-invalid');
            var existingFeedback = input.parentNode.querySelector('.invalid-feedback');
            if (existingFeedback) {
                existingFeedback.remove();
            }
            
            // Валидация
            if (value > maxValue) {
                input.classList.add('is-invalid');
                var feedback = document.createElement('div');
                feedback.className = 'invalid-feedback';
                feedback.textContent = fieldName + ' не могат да надвишават ' + maxValue;
                input.parentNode.appendChild(feedback);
                isValid = false;
            } else if (value < 0) {
                input.classList.add('is-invalid');
                var feedback = document.createElement('div');
                feedback.className = 'invalid-feedback';
                feedback.textContent = 'Часовете не могат да бъдат отрицателни';
                input.parentNode.appendChild(feedback);
                isValid = false;
            }
            
            return isValid;
        }
        
        // Валидация при промяна
        theoryInput.addEventListener('input', function() {
            validateHours(this, maxTheory, 'Часовете теория');
        });
        
        practiceInput.addEventListener('input', function() {
            validateHours(this, maxPractice, 'Часовете практика');
        });
        
        // Предотвратяване на submit ако има грешки
        form.addEventListener('submit', function(e) {
            var theoryValid = validateHours(theoryInput, maxTheory, 'Часовете теория');
            var practiceValid = validateHours(practiceInput, maxPractice, 'Часовете практика');
            
            if (!theoryValid || !practiceValid) {
                e.preventDefault();
                alert('Моля, коригирайте грешките във формата преди да запазите.');
            }
        });
    });
</script>

<section class="page-header-modern">
    <div class="container">
        <h1 class="page-title">Редактирай записване за курс</h1>
        <p class="page-subtitle">@(Model.CourseInstances?.Courses?.Name) – @(Model.Student?.FirstName) @(Model.Student?.LastName)</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Курс (текущ курс)</label>
                            <select name="courseInstanceId" class="form-select" asp-items="ViewBag.CourseInstanceId"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Клиент (курсист)</label>
                            <select name="studentId" class="form-select" asp-items="ViewBag.StudentId"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Инструктор</label>
                            <select name="instructorId" class="form-select" asp-items="ViewBag.InstructorId"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Автомобил</label>
                            <select name="vehicleId" class="form-select" asp-items="ViewBag.VehicleId"></select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Дата и час на заявката</label>
                            <input name="createAt" class="form-control" type="datetime-local" value="@Model.CreateAt.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Часове теория</label>
                            <input name="currentTheoryHours" class="form-control" type="number" value="@Model.CurrentTheoryHours" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Часове практика</label>
                            <input name="currentPracticeHours" class="form-control" type="number" value="@Model.CurrentPracticeHours" />
                        </div>
                    </div>
                    <hr class="my-4" />
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn-modern btn-primary-modern">
                            <i class="fas fa-save"></i> Запази
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-modern btn-secondary-modern">Отказ</a>
                        <a asp-action="Index" class="btn-modern btn-secondary-modern">
                            <i class="fas fa-arrow-left"></i> Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
